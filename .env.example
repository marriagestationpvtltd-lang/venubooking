DB_HOST=localhost
# Your MySQL database name
DB_NAME=your_database_name
# Your MySQL database username
DB_USER=your_database_user
# Your MySQL database password (use a strong password with at least 12 characters)
DB_PASS=your_database_password

# Application base URL (optional but STRONGLY recommended on shared hosting)
# Set this to the full URL of your site root WITHOUT a trailing slash.
# Examples:
#   APP_URL=https://yourdomain.com
#   APP_URL=https://yourdomain.com/venubooking
# When not set, the URL is detected automatically from the request, which can
# fail on some Nginx + PHP-FPM setups or behind reverse proxies, causing photo
# and video previews to show as "Image unavailable".
# APP_URL=https://yourdomain.com

# DEPRECATED: Currency and Tax Rate are now managed in Admin Panel → Settings
# These values are no longer used - all settings are database-driven
# CURRENCY=NPR
# TAX_RATE=13

# Email / Notification Settings
# These are used as fallback when values are not set in Admin Panel → Settings → Email Settings
# Set MAIL_NOTIFICATIONS_ENABLED=1 to enable email notifications (default: 1)
MAIL_NOTIFICATIONS_ENABLED=1
MAIL_FROM_NAME=Venue Booking System
MAIL_FROM_ADDRESS=noreply@yourdomain.com
# Admin email to receive booking notifications
MAIL_ADMIN_EMAIL=admin@yourdomain.com

# SMTP Configuration
# IMPORTANT: PHP mail() (MAIL_SMTP_ENABLED=0) sends unauthenticated mail from your
# server IP and will be rejected by Gmail and other providers with SPF/DKIM errors.
# Always use SMTP with an authenticated account (e.g. Gmail, SendGrid, Mailgun).
#
# When SMTP is enabled the system uses MAIL_USERNAME as the envelope sender so that
# SPF and DKIM alignment checks pass. Set MAIL_USERNAME to the email address you are
# authenticating with on the SMTP server.
#
# For Gmail (TLS): MAIL_HOST=smtp.gmail.com, MAIL_PORT=587, MAIL_ENCRYPTION=tls
# For Gmail (SSL): MAIL_HOST=smtp.gmail.com, MAIL_PORT=465, MAIL_ENCRYPTION=ssl
# For Gmail you must use an App Password (not your regular password):
#   https://myaccount.google.com/apppasswords
MAIL_SMTP_ENABLED=1
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
