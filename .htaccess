# ============================================================================
# PRODUCTION SECURITY CONFIGURATION
# Venue Booking System - Apache .htaccess
# ============================================================================

# Disable directory listing
Options -Indexes

# Follow symbolic links
Options +FollowSymLinks

# Enable URL rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
</IfModule>

# ============================================================================
# BLOCK ACCESS TO SENSITIVE FILES
# ============================================================================

# Deny access to .env and environment files
<FilesMatch "^\.env(\..*)?$">
    Require all denied
</FilesMatch>

# Deny access to .git directory
<IfModule mod_rewrite.c>
    RewriteRule ^\.git(/.*)?$ - [F,L]
</IfModule>

# Deny access to PHP configuration and sensitive files
<FilesMatch "\.(ini|log|sh|sql|bak|swp|orig|example)$">
    Require all denied
</FilesMatch>

# Deny access to hidden files (starting with a dot) except .htaccess itself
<FilesMatch "^\.(?!htaccess)">
    Require all denied
</FilesMatch>

# ============================================================================
# SECURITY HEADERS
# ============================================================================

<IfModule mod_headers.c>
    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Enable XSS filter in older browsers
    Header always set X-XSS-Protection "1; mode=block"

    # Control referrer information
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Remove the X-Powered-By header that exposes PHP version
    Header always unset X-Powered-By

    # Permissions Policy (disable unnecessary browser features)
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Strict-Transport-Security (HSTS) — enforces HTTPS for 1 year
    # Only enable once HTTPS is fully configured on the server
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Content Security Policy
    # Allows same-origin scripts/styles plus the CDNs used by the application.
    # TODO: Remove 'unsafe-inline' from script-src and style-src by migrating
    # inline scripts/styles to external files or using nonce-based CSP. Keeping
    # 'unsafe-inline' for now to avoid breaking existing functionality.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' blob: https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://www.googletagmanager.com https://code.jquery.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com; img-src 'self' data: blob: https://www.google-analytics.com; font-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://fonts.gstatic.com; connect-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://www.google-analytics.com https://www.googletagmanager.com; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
</IfModule>

# ============================================================================
# PHP SECURITY SETTINGS
# ============================================================================

<IfModule mod_php.c>
    # Hide PHP version
    php_flag expose_php Off
    # Disable display of errors in production
    php_flag display_errors Off
    php_flag display_startup_errors Off
    php_flag log_errors On
    # Allow uploads up to 55 MB (covers the 50 MB photo limit with some headroom)
    php_value upload_max_filesize 55M
    php_value post_max_size 60M
    # Download scripts disable their own time limit via set_time_limit(0).
    # Use 3600 s (1 h) here as a safety ceiling for all other scripts.
    php_value max_execution_time 3600
    php_value max_input_time 300
    # Disable zlib output compression globally so download scripts are not
    # forced to fight against a hidden buffer they cannot ob_end_clean() away.
    php_flag zlib.output_compression Off
</IfModule>

<IfModule mod_php8.c>
    php_flag expose_php Off
    php_flag display_errors Off
    php_flag display_startup_errors Off
    php_flag log_errors On
    php_value upload_max_filesize 55M
    php_value post_max_size 60M
    php_value max_execution_time 3600
    php_value max_input_time 300
    php_flag zlib.output_compression Off
</IfModule>

# ============================================================================
# DISABLE RESPONSE COMPRESSION FOR FILE DOWNLOAD SCRIPTS
# ============================================================================
# folder.php and download.php stream binary files directly to the client.
# Allowing mod_deflate to compress these responses causes the server to
# buffer the entire output before sending it, which produces incomplete
# downloads for large files and prevents the instant-start behaviour.
<IfModule mod_deflate.c>
    SetEnvIfNoCase Request_URI folder\.php no-gzip dont-vary
    SetEnvIfNoCase Request_URI download\.php no-gzip dont-vary
    SetEnvIfNoCase Request_URI api/download-zip\.php no-gzip dont-vary

    # Enable gzip compression for text-based content (HTML, CSS, JS, JSON, XML).
    # This reduces bandwidth for all pages by 60–80% with negligible CPU cost.
    # The above SetEnvIf rules already exclude folder.php and download.php.
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml application/xhtml+xml
</IfModule>

# ============================================================================
# BROWSER CACHING – REDUCE REPEAT BANDWIDTH
# ============================================================================
# Uploaded images and static vendor assets never change under the same URL,
# so telling browsers to cache them for 7 days means repeat visitors download
# them once instead of on every page view.

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg  "access plus 7 days"
    ExpiresByType image/png   "access plus 7 days"
    ExpiresByType image/webp  "access plus 7 days"
    ExpiresByType image/gif   "access plus 7 days"
    ExpiresByType image/svg+xml "access plus 7 days"
    ExpiresByType text/css    "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType application/x-javascript "access plus 7 days"
    ExpiresByType font/woff   "access plus 30 days"
    ExpiresByType font/woff2  "access plus 30 days"
    ExpiresByType application/font-woff  "access plus 30 days"
    ExpiresByType application/font-woff2 "access plus 30 days"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "(?i)\.(jpg|jpeg|png|gif|webp|bmp|ico|svg)$">
        Header set Cache-Control "public, max-age=604800, must-revalidate"
    </FilesMatch>
    <FilesMatch "(?i)\.(css|js)$">
        Header set Cache-Control "public, max-age=604800, must-revalidate"
    </FilesMatch>
    <FilesMatch "(?i)\.(woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
</IfModule>

# ============================================================================
# PROTECT CONFIGURATION DIRECTORY
# ============================================================================
# Note: Apache does not apply directory-level .htaccess rules from the parent
# for sub-directories unless AllowOverride is set. As a belt-and-suspenders
# measure, deny direct access to the config/ directory here as well.

<IfModule mod_rewrite.c>
    RewriteRule ^config(/.*)?$ - [F,L]
    RewriteRule ^includes(/.*)?$ - [F,L]
    RewriteRule ^database(/.*)?$ - [F,L]
</IfModule>
