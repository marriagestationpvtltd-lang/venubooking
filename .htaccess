# ============================================================================
# PRODUCTION SECURITY CONFIGURATION
# Venue Booking System - Apache .htaccess
# ============================================================================

# Disable directory listing
Options -Indexes

# Follow symbolic links
Options +FollowSymLinks

# Enable URL rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>

# ============================================================================
# BLOCK ACCESS TO SENSITIVE FILES
# ============================================================================

# Deny access to .env and environment files
<FilesMatch "^\.env(\..*)?$">
    Require all denied
</FilesMatch>

# Deny access to .git directory
<IfModule mod_rewrite.c>
    RewriteRule ^\.git(/.*)?$ - [F,L]
</IfModule>

# Deny access to PHP configuration and sensitive files
<FilesMatch "\.(ini|log|sh|sql|bak|swp|orig|example)$">
    Require all denied
</FilesMatch>

# Deny access to hidden files (starting with a dot) except .htaccess itself
<FilesMatch "^\.(?!htaccess)">
    Require all denied
</FilesMatch>

# ============================================================================
# SECURITY HEADERS
# ============================================================================

<IfModule mod_headers.c>
    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Enable XSS filter in older browsers
    Header always set X-XSS-Protection "1; mode=block"

    # Control referrer information
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Remove the X-Powered-By header that exposes PHP version
    Header always unset X-Powered-By

    # Permissions Policy (disable unnecessary browser features)
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Strict-Transport-Security (HSTS) — enforces HTTPS for 1 year
    # Only enable once HTTPS is fully configured on the server
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Content Security Policy
    # Allows same-origin scripts/styles plus the CDNs used by the application.
    # TODO: Remove 'unsafe-inline' from script-src and style-src by migrating
    # inline scripts/styles to external files or using nonce-based CSP. Keeping
    # 'unsafe-inline' for now to avoid breaking existing functionality.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' blob: https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; img-src 'self' data: blob:; font-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; connect-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
</IfModule>

# ============================================================================
# PHP SECURITY SETTINGS
# ============================================================================

<IfModule mod_php.c>
    # Hide PHP version
    php_flag expose_php Off
    # Disable display of errors in production
    php_flag display_errors Off
    php_flag display_startup_errors Off
    php_flag log_errors On
    # Allow uploads up to 55 MB (covers the 50 MB photo limit with some headroom)
    php_value upload_max_filesize 55M
    php_value post_max_size 60M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

<IfModule mod_php8.c>
    php_flag expose_php Off
    php_flag display_errors Off
    php_flag display_startup_errors Off
    php_flag log_errors On
    php_value upload_max_filesize 55M
    php_value post_max_size 60M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

# ============================================================================
# PROTECT CONFIGURATION DIRECTORY
# ============================================================================
# Note: Apache does not apply directory-level .htaccess rules from the parent
# for sub-directories unless AllowOverride is set. As a belt-and-suspenders
# measure, deny direct access to the config/ directory here as well.

<IfModule mod_rewrite.c>
    RewriteRule ^config(/.*)?$ - [F,L]
    RewriteRule ^includes(/.*)?$ - [F,L]
    RewriteRule ^database(/.*)?$ - [F,L]
</IfModule>
