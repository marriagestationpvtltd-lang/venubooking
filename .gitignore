# Environment configuration
.env
.env.production

# Logs directory content (keep directory structure but ignore log files)
logs/*
!logs/.htaccess
!logs/.gitkeep
*.log
error_log
access_log

# Uploaded files (keep directory structure but ignore content)
uploads/**/*
!uploads/.gitkeep
!uploads/.htaccess
!uploads/venues/.gitkeep
!uploads/halls/.gitkeep
!uploads/menus/.gitkeep

# IDE and Editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# Logs
*.log
error_log
access_log

# Cache and temporary files
*.cache
*.tmp
*.bak
*.swp
*~

# Vendor directories (if using Composer) — root-level only
/vendor/
composer.lock

# Admin frontend vendor (Bootstrap, jQuery etc.) — track these
!/admin/vendor/

# Node modules (if using npm)
node_modules/
package-lock.json

# Build artifacts
dist/
build/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# Database dumps
*.sql.gz
*.sql.zip
backup/

# PHP
.php_cs.cache

