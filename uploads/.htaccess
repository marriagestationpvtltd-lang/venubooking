# Deny execution of PHP scripts and other server-side scripts in the uploads directory.
# This prevents attackers from executing malicious files they may have uploaded.

# Deny direct PHP execution
<FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|phar|pl|py|cgi|sh|bash|exe|htaccess)$">
    Require all denied
</FilesMatch>

# Security header to prevent MIME type sniffing attacks
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>

# Allow images and videos to be displayed inline (for preview functionality)
# while forcing other file types to download as attachments
<IfModule mod_headers.c>
    # Default: force download for all files with extensions
    <FilesMatch "\..+$">
        Header set Content-Disposition "attachment"
    </FilesMatch>
    
    # Override for safe image formats: allow inline display for previews
    # Note: SVG is intentionally excluded as it can contain embedded JavaScript (XSS risk)
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|bmp|ico)$">
        Header set Content-Disposition "inline"
    </FilesMatch>
    
    # Override for videos: allow inline display for video player
    <FilesMatch "\.(mp4|webm|ogg|mov|avi|mkv|m4v|3gp)$">
        Header set Content-Disposition "inline"
    </FilesMatch>
</IfModule>

# Deny directory listing
Options -Indexes
