# Deny execution of PHP scripts and other server-side scripts in the uploads directory.
# This prevents attackers from executing malicious files they may have uploaded.

# Deny direct PHP execution
<FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|phar|pl|py|cgi|sh|bash|exe|htaccess)$">
    Require all denied
</FilesMatch>

# Security headers for all files
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>

# Force attachment (download) by default for all files to prevent XSS attacks.
# Only safe image and video formats are explicitly allowed inline for browser display.
# Note: SVG is intentionally excluded from inline display due to XSS risk (can contain JavaScript).
<IfModule mod_headers.c>
    # Default: force attachment for all files (secure default)
    Header set Content-Disposition "attachment"
    
    # Whitelist: allow inline display only for safe image and video formats
    <FilesMatch "\.(?i:jpg|jpeg|png|gif|webp|mp4|webm|ogg|mov|avi|mkv)$">
        Header set Content-Disposition "inline"
    </FilesMatch>
</IfModule>

# Deny directory listing
Options -Indexes
