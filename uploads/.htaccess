# Deny execution of PHP scripts and other server-side scripts in the uploads directory.
# This prevents attackers from executing malicious files they may have uploaded.

# Deny direct PHP execution
<FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|phar|pl|py|cgi|sh|bash|exe|htaccess)$">
    Require all denied
</FilesMatch>

# Security headers for all files
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>

# Force attachment (download) for non-media files to prevent XSS attacks.
# Images and videos are allowed inline so they can be displayed in the browser.
<IfModule mod_headers.c>
    <FilesMatch "\.(?i:jpg|jpeg|png|gif|webp|svg|mp4|webm|ogg|mov|avi|mkv)$">
        Header set Content-Disposition "inline"
    </FilesMatch>
    <FilesMatch "\.(?i:pdf|doc|docx|xls|xlsx|zip|rar|7z|tar|gz|txt|csv)$">
        Header set Content-Disposition "attachment"
    </FilesMatch>
</IfModule>

# Deny directory listing
Options -Indexes
